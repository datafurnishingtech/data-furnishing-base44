# Copy to .env.local for local dev, OR set the same keys in Base44 → app Settings → Environment variables.

# Required — Supabase (auth + live registry data)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Comma-separated emails that get admin + auto-approved access
VITE_SUPER_ADMIN_EMAILS=admin1@example.com,admin2@example.com

# Set to false to skip the approval gate during development
VITE_ENABLE_ACCESS_GATE=true

# Optional — only if you still use Base44 /api routes locally (silences proxy log)
# VITE_BASE44_APP_ID=your_app_id
# VITE_BASE44_APP_BASE_URL=https://your-app.base44.app
